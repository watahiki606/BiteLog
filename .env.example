# ローカル実行用
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=/Users/yourname/path/to/AuthKey_XXXXXXXXXX.p8
KEYCHAIN_PASSWORD=your_mac_login_password

# GitHub Actions用 Secret（ASC_KEY_CONTENT）の作り方:
#   base64 -i /path/to/AuthKey_XXXXX.p8 | pbcopy
# → コピーした内容を GitHub Secrets に ASC_KEY_CONTENT として登録
