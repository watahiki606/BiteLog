default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = if ENV["CI"]
      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        duration: 1200,
        in_house: false,
        is_key_content_base64: true
      )
    else
      app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: ENV["ASC_KEY_FILEPATH"],
        duration: 1200,
        in_house: false
      )
    end

    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(build_number: build_number)

    unless ENV["CI"]
      cert(
        api_key: api_key,
        keychain_password: ENV["KEYCHAIN_PASSWORD"]
      )
    end

    sigh(
      app_identifier: "com.watahiki.BiteLog",
      api_key: api_key,
      force: true
    )

    gym_params = {
      scheme: "BiteLog",
      export_method: "app-store",
      configuration: "Release",
      clean: true
    }

    if ENV["CI"]
      gym_params[:xcargs] = [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath /tmp/auth_key.p8",
        "-authenticationKeyID #{ENV['ASC_KEY_ID']}",
        "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']}"
      ].join(" ")
    else
      gym_params[:export_options] = {
        signingStyle: "automatic",
        provisioningProfiles: {
          "com.watahiki.BiteLog" => ENV["SIGH_NAME"]
        }
      }
    end

    gym(gym_params)

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
